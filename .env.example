# Required for polite SEC EDGAR access. Use a real app/contact identity.
WARROOM_SEC_USER_AGENT="War Room OS your-email@example.com"

# Optional paid institutional feeds
UNUSUAL_WHALES_API_KEY=""
MASSIVE_API_KEY=""
NANSEN_API_KEY=""
