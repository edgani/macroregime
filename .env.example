# Required for polite SEC EDGAR access. Use a real app/contact identity.
WARROOM_SEC_USER_AGENT="War Room OS your-email@example.com"

# Optional paid institutional feeds
UNUSUAL_WHALES_API_KEY=""
MASSIVE_API_KEY=""
NANSEN_API_KEY=""
ARKHAM_API_KEY=""

# Optional comma-separated symbols. Otherwise War Room uses its current shortlist.
WARROOM_WATCHLIST="NVDA,AMD,TSM,SPY"

# Existing macro/data credentials supported by the original project
FRED_API_KEY=""

# --- Live derivatives / squeeze state ---------------------------------------
# US option-chain snapshots, Greeks, quotes/trades and prior-cleared OI.
# Reuses MASSIVE_API_KEY above.
WARROOM_OPTIONS_WATCHLIST="SPY,QQQ,NVDA,AMD,TSLA"
WARROOM_OPTIONS_MAX_TICKERS="5"

# Persistent Unusual Whales Kafka/WebSocket worker should expose a normalized
# HTTP snapshot containing live-gex, Greek flow, net flow, IV term and option state.
UNUSUAL_WHALES_STREAM_BRIDGE_URL=""
UNUSUAL_WHALES_STREAM_BRIDGE_TOKEN=""

# Live/estimated short interest, cost-to-borrow, days-to-cover and free float.
ORTEX_API_KEY=""
ORTEX_API_KEY_HEADER="Authorization"
ORTEX_API_KEY_PREFIX="Bearer"
ORTEX_DEFAULT_EXCHANGE="US"
# JSON map when your ORTEX plan requires an exchange code per ticker.
ORTEX_EXCHANGE_MAP='{"NVDA":"NASDAQ","AMD":"NASDAQ","SPY":"ARCA"}'

# Settlement-based official short-interest fallback; not real time.
INTRINIO_API_KEY=""

# Cross-exchange crypto OI/funding/liquidation analytics.
COINGLASS_API_KEY=""

# Public crypto derivatives feeds (no API key required).
WARROOM_CRYPTO_DERIVATIVES="BTC,ETH,SOL"
BINANCE_FUTURES_BASE_URL="https://fapi.binance.com"
BYBIT_BASE_URL="https://api.bybit.com"
OKX_BASE_URL="https://www.okx.com"
DERIBIT_BASE_URL="https://www.deribit.com"

# Optional provider base URL overrides for regional proxy / enterprise gateways.
MASSIVE_BASE_URL="https://api.massive.com"
ORTEX_BASE_URL="https://api.ortex.com"
INTRINIO_BASE_URL="https://api-v2.intrinio.com"
COINGLASS_BASE_URL="https://open-api-v4.coinglass.com"

# Optional persistent Massive WebSocket bridge.
MASSIVE_STREAM_BRIDGE_URL=""
MASSIVE_STREAM_BRIDGE_TOKEN=""
MASSIVE_STREAM_STOCKS="SPY,QQQ,NVDA,AMD,TSLA"
# Use only subscriptions allowed by your entitlement, for example exact option contracts.
MASSIVE_OPTIONS_SUBSCRIPTIONS=""

# --- Runtime resiliency -----------------------------------------------------
# live = use network; offline = use only last-good caches and explicit OFFLINE states.
WARROOM_NETWORK_MODE="live"
WARROOM_HTTP_TIMEOUT="8"

# --- Unusual Whales persistent stream -------------------------------------
# Kafka delivery is protobuf. Supply a local decoder module with:
# decode(topic: str, value: bytes, key: bytes|None) -> dict
UW_KAFKA_DECODER_MODULE=""
UW_KAFKA_ALLOW_JSON="0"
UW_KAFKA_BOOTSTRAP_SERVERS=""
UW_KAFKA_USERNAME=""
UW_KAFKA_PASSWORD=""
UW_KAFKA_GROUP_ID="warroom-os"
UW_KAFKA_TOPICS="greek-flow,live-gex,net-flow,option-states,interpolated-iv,iv-term-structure,risk-reversal-skew,interval-flow,chain-frag,multi-leg-spreads,flow-alerts,all-option-trades,all-trade-report,sec-filings,ticker-stock-states,trading-halts"
UW_BRIDGE_HOST="127.0.0.1"
UW_BRIDGE_PORT="8765"
UW_BRIDGE_TOKEN=""

# Optional provider-supplied JSON WebSocket gateway when your entitlement uses one.
UW_WEBSOCKET_URL=""
UW_WEBSOCKET_HEADERS_JSON='{}'
UW_WEBSOCKET_AUTH_MESSAGE_JSON='{}'
UW_WEBSOCKET_SUBSCRIBE_MESSAGES_JSON='[]'

# --- Databento futures/options exchange bridge -----------------------------
DATABENTO_API_KEY=""
DATABENTO_STREAM_BRIDGE_URL="http://127.0.0.1:8767/snapshot"
DATABENTO_STREAM_BRIDGE_TOKEN=""
DATABENTO_BRIDGE_HOST="127.0.0.1"
DATABENTO_BRIDGE_PORT="8767"
DATABENTO_SUBSCRIPTIONS_JSON='[{"dataset":"GLBX.MDP3","schema":"statistics","stype_in":"parent","symbols":["ES.FUT","NQ.FUT","CL.FUT","GC.FUT"]},{"dataset":"GLBX.MDP3","schema":"trades","stype_in":"parent","symbols":["ES.FUT","NQ.FUT","CL.FUT","GC.FUT"]}]'

# --- Official physical/fundamental data -----------------------------------
EIA_API_KEY=""
# Optional list of EIA API v2 requests. Keep route/facets explicit.
EIA_REQUESTS_JSON=""
WARROOM_ETF_FLOW_WATCHLIST="SPY,QQQ,IWM,SMH,XLF,XLE,XLK,XLI,GLD,TLT,EEM,EIDO"

# --- Licensed Indonesia market bridge -------------------------------------
# Must be backed by a legitimate IDX/vendor feed. Expected rows may contain:
# ticker, timestamp, foreign_net, broker_code, broker_net_value, avg_buy,
# avg_sell, bid_levels, ask_levels, free_float, controller, source_sequence.
IDX_DATA_BRIDGE_URL=""
IDX_DATA_BRIDGE_TOKEN=""

# --- Hosted runtime / worker ------------------------------------------------
# Managed deployments default to a standalone collector process. The app automatically falls
# back to an embedded worker when detached process startup is unavailable.
WARROOM_WORKER_MODE="process"
WARROOM_NETWORK_MODE="live"
WARROOM_HTTP_TIMEOUT="8"
WARROOM_INITIAL_CORE_RETRY_SECONDS="60"

# First paint is price-first: market state loads before slower macro/enrichment planes.
WARROOM_FAST_CORE_PRICE_FIRST="1"
WARROOM_FAST_CORE_HARD_TIMEOUT="18"
WARROOM_FAST_US_NAMES="12"
WARROOM_FAST_IDX_NAMES="8"
WARROOM_FAST_CRYPTO_NAMES="10"

# Hosted price path uses Yahoo chart HTTP with explicit timeouts. Local users may switch to
# WARROOM_PRICE_BACKEND="hybrid" and enable yfinance fallback.
WARROOM_PRICE_BACKEND="http"
WARROOM_PRICE_HTTP_TIMEOUT="4"
WARROOM_PRICE_HTTP_WORKERS="16"
WARROOM_YAHOO_SECONDARY="0"
WARROOM_ENABLE_YFINANCE_FALLBACK="0"
WARROOM_YF_TIMEOUT="8"
WARROOM_YF_BATCH_SIZE="40"
WARROOM_YF_RETRY_CAP="2"
WARROOM_PRICE_MEMORY_TTL="120"
WARROOM_PRICE_DISK_TTL="300"

# Independent refresh planes.
WARROOM_CORE_REFRESH_SECONDS="300"
WARROOM_EVENT_REFRESH_SECONDS="45"
WARROOM_SLOW_REFRESH_SECONDS="1800"
WARROOM_EXPANDED_REFRESH_SECONDS="3600"
WARROOM_EXPANDED_CORE_HARD_TIMEOUT="240"
WARROOM_EVENT_HARD_TIMEOUT="75"
WARROOM_SLOW_HARD_TIMEOUT="120"

# Macro and public official endpoints.
WARROOM_FRED_HTTP_TIMEOUT="6"
WARROOM_LIQUIDITY_TIMEOUT="5"
WARROOM_LIQUIDITY_CACHE_TTL="900"
WARROOM_PUBLIC_USER_AGENT="WarRoomOS/2.6 your-email@example.com"

# Always reserve options slots for liquid market anchors before candidate names.
WARROOM_OPTIONS_ANCHORS="SPY,QQQ,IWM,SMH,NVDA,AMD"
# Direct IDX HTML scraping is disabled by default; use the licensed bridge above.
WARROOM_ENABLE_IDX_SCRAPER="0"
